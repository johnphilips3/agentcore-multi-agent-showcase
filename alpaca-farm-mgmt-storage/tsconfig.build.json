{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "noEmitOnError": false,
    "skipLibCheck": true
  },
  "include": [
    "src/models/**/*",
    "src/database/pg-connection.ts",
    "src/repositories/pg-*.ts",
    "src/services/*.ts",
    "src/api/controllers/*.ts",
    "src/api/routes/**/*",
    "src/api/full-server.ts",
    "src/server.ts"
  ],
  "exclude": [
    "node_modules",
    "dist", 
    "**/*.test.ts",
    "src/__tests__/**/*",
    "src/api/__tests__/**/*"
  ]
}