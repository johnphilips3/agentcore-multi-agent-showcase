{
  "name": "alpaca-herd-storage",
  "version": "1.0.0",
  "description": "Persistent storage system for alpaca herd management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:full": "tsc",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:unit": "vitest --run --config vitest.config.ts",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:performance": "vitest --run --config vitest.performance.config.ts",
    "test:silent": "vitest --run --reporter=basic",
    "test:verbose": "vitest --run --reporter=verbose",
    "test:debug": "vitest --run --no-coverage --reporter=verbose --bail=1",
    "test:runner": "node scripts/test-runner.js",
    "test:validate": "node scripts/validate-tests.js",
    "start": "node dist/server.js",
    "dev:server": "npm run build && npm run start"
  },
  "keywords": [
    "alpaca",
    "herd",
    "management",
    "storage",
    "database"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/glob": "^8.1.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/yamljs": "^0.2.34",
    "glob": "^11.0.3",
    "supertest": "^6.3.4",
    "typescript": "^5.9.2",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/pg": "^8.15.5",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "aws-sdk": "^2.1692.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^13.0.0",
    "yamljs": "^0.3.0"
  }
}
